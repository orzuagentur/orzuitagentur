# OrzuIT — Umgebungsvariablen (Beispiel)
# Kopieren Sie nach `.env.local` und füllen Sie die Werte aus.

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Impressum / Datenschutz (optional — sonst CMS-Footer & Platzhalter) ─────
NEXT_PUBLIC_LEGAL_BRAND=OrzuIT
NEXT_PUBLIC_LEGAL_COMPANY=OrzuIT
NEXT_PUBLIC_LEGAL_REPRESENTATIVE=
NEXT_PUBLIC_LEGAL_ADDRESS_LINE1=
NEXT_PUBLIC_LEGAL_ADDRESS_LINE2=
NEXT_PUBLIC_LEGAL_EMAIL=
NEXT_PUBLIC_LEGAL_PHONE=
NEXT_PUBLIC_LEGAL_VAT_ID=
NEXT_PUBLIC_LEGAL_REGISTER_COURT=
NEXT_PUBLIC_LEGAL_REGISTER_NUMBER=

# ── Supabase (Projekt-Einstellungen → API) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nur Server (niemals im Browser exponieren):
SUPABASE_SERVICE_ROLE_KEY=

# Komma-getrennte Admin-E-Mails für `/dashboard` (Login mit Passwort)
ADMIN_EMAILS=admin@beispiel.de

# ── Resend (Team-Benachrichtigung + Bestätigung an den Kunden) ───────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=OrzuIT <onboarding@resend.dev>
LEAD_NOTIFY_EMAIL=kontakt@orzuit.de

# ── Telegram (optional: Bot-Token + Chat-ID) ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Vercel Control Center (/dashboard/deploy) — nur Server ───────────────────
# Token: https://vercel.com/account/settings/tokens
VERCEL_ACCESS_TOKEN=
# Project ID: Vercel → Project → Settings → General
VERCEL_PROJECT_ID=
# Optional bei Team-Accounts
VERCEL_TEAM_ID=
# Optional: Deploy Hook URL (nur Redeploy ohne volle API)
VERCEL_DEPLOY_HOOK_URL=
